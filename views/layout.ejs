<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Superhéroes App</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>

    <!-- NAVBAR HARDCODEADA -->
    <header class="navbar <%= (typeof esLanding !== 'undefined' && esLanding) ? 'navbar-transparent' : 'navbar-solid' %>">
        <div class="nav-container">
            <div class="logo">
                <img src="/icons/logoIcon.svg" alt="Logo">
                <span>Superhéroes App</span>
            </div>

            <!-- BOTÓN HAMBURGUESA -->
            <div class="menu-toggle" onclick="toggleMenu()">
                <img src="/icons/menu-icon.svg" alt="Menú" class="menu-icon">
            </div>

            <!-- MENÚ -->
            <nav id="nav-menu">
                <a href="/">Home</a>
                <a href="/heroes">Superhéroes</a>
                <a href="/acerca">Acerca</a>
                <a href="/contacto">Contacto</a>
            </nav>
        </div>
    </header>

    <!-- -->
    <% if (typeof esLanding === "undefined" || !esLanding) { %>
        <div class="container page-content">
            <%- body %>
        </div>
    <% } else { %>
        <%- body %>
    <% } %>

    <footer class="main-footer">
        <div class="footer-container">

            <p>© 2026 Superhéroes App - Powered by Marcos Batallán</p>

            <div class="footer-links">
                <a href="/">Home</a>
                <a href="/heroes">Superhéroes</a>
                <a href="/acerca">Acerca</a>
                <a href="/contacto">Contacto</a>
            </div>

        </div>
    </footer>

    <script>
        const menu = document.getElementById("nav-menu");
        const toggle = document.querySelector(".menu-toggle");

        function toggleMenu() {
            menu.classList.toggle("active");
            toggle.classList.toggle("active");
        }

        // 🔥 Cerrar al hacer click en un link
        document.querySelectorAll("#nav-menu a").forEach(link => {
            link.addEventListener("click", () => {
                menu.classList.remove("active");
                toggle.classList.remove("active");
            });
        });
    </script>

</body>
</html>