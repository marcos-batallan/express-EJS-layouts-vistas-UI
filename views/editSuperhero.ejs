<div class="container">
    <!-- ERRORES -->
    <% if (errores && errores.length > 0) { %>
        <div class="error">
            <ul>
                <% errores.forEach(error => { %>
                    <li><%= error.msg %></li>
                <% }) %>
            </ul>
        </div>
    <% } %>

    <form action="/api/heroes/<%= superhero._id %>/editar?_method=PUT" method="POST">

        <input type="text" name="nombreSuperHeroe"
            value="<%= datos?.nombreSuperHeroe || superhero.nombreSuperHeroe %>" required>

        <input type="text" name="nombreReal"
            value="<%= datos?.nombreReal || superhero.nombreReal %>" required>

        <input type="number" name="edad"
            value="<%= datos?.edad || superhero.edad %>" required>

        <input type="text" name="planetaOrigen"
            value="<%= datos?.planetaOrigen || superhero.planetaOrigen %>">

        <input type="text" name="debilidad"
            value="<%= datos?.debilidad || superhero.debilidad %>">

        <input type="text" name="poderes"
            value="<%= datos?.poderes || superhero.poderes.join(', ') %>" required>

        <input type="text" name="aliados"
            value="<%= datos?.aliados || (superhero.aliados?.join(', ') || '') %>">

        <input type="text" name="enemigos"
            value="<%= datos?.enemigos || (superhero.enemigos?.join(', ') || '') %>">

        <input type="text" name="creator"
            value="<%= datos?.creator || superhero.creator || '' %>">

        <button class="btn btn-save" type="submit">Actualizar</button>
    </form>

    <button class="btn btn-back" onclick="window.location.href='/heroes'">
        ⬅ Volver
    </button>
</div>